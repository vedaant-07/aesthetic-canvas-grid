# Public frontend variables
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxx

# Optional backend API bridge when connecting to the existing SE7EN FIT Render API
VITE_API_BASE_URL=https://se7en-fit-api.onrender.com/api

# Supabase Edge Function secrets. Set these in Supabase project secrets, not in the frontend Render site.
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_OR_PUBLISHABLE_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_SERVER_ONLY
ADMIN_UNLOCK_CODE=SE7EN-ADMIN-2026-CHANGE-ME
ADMIN_SESSION_SECRET=generate-a-long-random-secret-minimum-32-chars
ACCESS_CODE_PEPPER=generate-a-different-long-random-secret
